model StudentProfile {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  studentId      String   @unique
  phoneNumber    String   @unique
  whatsAppNumber String?
  gender         Gender?
  dateOfBirth    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  addresses Address[]
}

enum Gender {
  MALE
  FEMALE
}
